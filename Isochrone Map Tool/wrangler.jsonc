{
  "name": "isochronemaptool",
  "main": "cloudflare/worker.js",
  "compatibility_date": "2025-06-07",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "include": [
      "index.html",
      "styles.css",
      "app.js"
    ],
    "exclude": [
      "node_modules/**",
      ".git/**",
      "cloudflare/**",
      "scripts/**",
      "dist/**",
      "*.tar.gz"
    ],
    "run_worker_first": [
      "/api/*"
    ]
  }
}
